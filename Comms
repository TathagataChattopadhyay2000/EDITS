if (endpoint == "normal") {
  
  error_method_names_normal <-
    "For endpoint = 'normal', 'method_names' must be NULL or 'normal'"
  error_target_means <-
    "Providing either NULL or a numeric vector for the argument 'target_means'"
  
  if (!is.null(method_names)) {
    checkmate::assertCharacter(
      method_names,
      len         = 1,
      any.missing = FALSE,
      .var.name   = error_method_names_normal
    )
    checkmate::assertTRUE(
      identical(method_names, "normal"),
      .var.name = error_method_names_normal
    )
  }
  
  if (!is.null(target_means)) {
    checkmate::assertNumeric(
      target_means,
      any.missing = FALSE,
      .var.name   = error_target_means
    )
  }
  
  return(getPriorParametersNormal(
    target_means = target_means,
    mu_pop_mean  = mu_pop_mean,
    mu_pop_sd    = mu_pop_sd,
    tau_shape    = tau_shape,
    tau_rate     = tau_rate,
    sigma_shape  = sigma_shape,
    sigma_rate   = sigma_rate
  ))
}
