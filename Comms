## normal ####

getPriorParametersNormal <- function (
    
  target_means,
  tau_scale   = 1,
  n_worth     = 1,
  w_j         = 0.5,
  sigma_shape = 1,
  sigma_rate  = 1
  
) {
  
  error_target_means <-
    "Providing a numeric vector for the argument 'target_means'"
  error_tau_scale <-
    "Providing a positive numeric for the argument 'tau_scale'"
  error_n_worth <-
    "Providing a positive integer for the argument 'n_worth'"
  error_w_j <-
    "Providing a numeric in (0, 1) for the argument 'w_j'"
  error_sigma_shape <-
    "Providing a positive numeric for the argument 'sigma_shape'"
  error_sigma_rate <-
    "Providing a positive numeric for the argument 'sigma_rate'"
  
  checkmate::assertNumeric(
    target_means,
    any.missing = FALSE,
    .var.name   = error_target_means
  )
  
  checkmate::assertNumber(
    tau_scale,
    .var.name = error_tau_scale
  )
  checkmate::assertTRUE(
    tau_scale > 0,
    .var.name = error_tau_scale
  )
  
  checkmate::assertInt(
    n_worth,
    lower     = 1,
    .var.name = error_n_worth
  )
  
  checkmate::assertNumeric(
    w_j,
    lower     = 0,
    upper     = 1,
    len       = 1,
    .var.name = error_w_j
  )
  
  checkmate::assertNumber(
    sigma_shape,
    .var.name = error_sigma_shape
  )
  checkmate::assertTRUE(
    sigma_shape > 0,
    .var.name = error_sigma_shape
  )
  
  checkmate::assertNumber(
    sigma_rate,
    .var.name = error_sigma_rate
  )
  checkmate::assertTRUE(
    sigma_rate > 0,
    .var.name = error_sigma_rate
  )
  
  prior_parameters <- list(
    mu_mean      = 0,
    mu_sd        = sqrt(1 / n_worth),
    tau_scale    = tau_scale,
    mu_j         = rep(0, length(target_means)),
    tau_j        = rep(sqrt(1 / n_worth), length(target_means)),
    w_j          = w_j,
    target_means = target_means,
    sigma_shape  = sigma_shape,
    sigma_rate   = sigma_rate
  )
  
  prior_parameters_list <- list(normal = prior_parameters)
  class(prior_parameters_list) <- "prior_parameters_list"
  
  return(prior_parameters_list)
}

#' @title setPriorParametersNormal
#' @md
#' @description This function sets prior parameters for the analysis method `"normal"`
#' for use in \code{\link[bhmbasket]{performAnalyses}}.
#' @param mu_mean A numeric for the mean of the Ex component.
#' @param mu_sd A positive numeric for the standard deviation of the Ex component.
#' @param tau_scale A positive numeric for the scale parameter of the Half-normal
#' prior on the between-cohort standard deviation \eqn{\tau}.
#' @param mu_j A numeric vector for the means of the Nex components.
#' @param tau_j A positive numeric vector for the standard deviations of the Nex components.
#' @param w_j A numeric in `(0, 1)` for the weight of the Ex component.
#' @param target_means A numeric vector of target means for each cohort.
#' These are used as additive offsets in the adjusted normal ExNex model.
#' @param sigma_shape A positive numeric for the Gamma shape prior of the residual precision.
#' @param sigma_rate A positive numeric for the Gamma rate prior of the residual precision.
#' @return A list with prior parameters of class `prior_parameters_list`
#' @details
#' The method `"normal"` is an adjusted ExNex hierarchical normal model for continuous endpoints.
#' The prior parameters specify the Ex component, the cohort-specific Nex components,
#' the Ex/Nex mixture weight, the target means used for adjustment, and the residual
#' precision prior.
#' @author Stephan Wojciekowski
#' @examples
#' prior_parameters_normal <- setPriorParametersNormal(
#'   mu_mean      = 0,
#'   mu_sd        = 1,
#'   tau_scale    = 1,
#'   mu_j         = c(0, 0, 0),
#'   tau_j        = c(1, 1, 1),
#'   w_j          = 0.5,
#'   target_means = c(5, 5, 5),
#'   sigma_shape  = 1,
#'   sigma_rate   = 1
#' )
#' @rdname setPriorParametersNormal
#' @seealso
#'  \code{\link[bhmbasket]{performAnalyses}}
#'  \code{\link[bhmbasket]{getPriorParameters}}
#'  \code{\link[bhmbasket]{combinePriorParameters}}
#' @export
setPriorParametersNormal <- function (
    
  mu_mean,
  mu_sd,
  tau_scale,
  mu_j,
  tau_j,
  w_j,
  target_means,
  sigma_shape,
  sigma_rate
  
) {
  
  error_mu_mean <-
    "Providing a numeric for the argument 'mu_mean'"
  error_mu_sd <-
    "Providing a positive numeric for the argument 'mu_sd'"
  error_tau_scale <-
    "Providing a positive numeric for the argument 'tau_scale'"
  error_mu_j <-
    "Providing a numeric vector for the argument 'mu_j'"
  error_tau_j <-
    "Providing a positive numeric vector for the argument 'tau_j'"
  error_w_j <-
    "Providing a numeric in (0, 1) for the argument 'w_j'"
  error_target_means <-
    "Providing a numeric vector for the argument 'target_means'"
  error_sigma_shape <-
    "Providing a positive numeric for the argument 'sigma_shape'"
  error_sigma_rate <-
    "Providing a positive numeric for the argument 'sigma_rate'"
  
  checkmate::assertNumber(mu_mean, .var.name = error_mu_mean)
  
  checkmate::assertNumber(mu_sd, .var.name = error_mu_sd)
  checkmate::assertTRUE(mu_sd > 0, .var.name = error_mu_sd)
  
  checkmate::assertNumber(tau_scale, .var.name = error_tau_scale)
  checkmate::assertTRUE(tau_scale > 0, .var.name = error_tau_scale)
  
  checkmate::assertNumeric(mu_j, any.missing = FALSE, .var.name = error_mu_j)
  
  checkmate::assertNumeric(tau_j, any.missing = FALSE, .var.name = error_tau_j)
  checkmate::assertTRUE(all(tau_j > 0), .var.name = error_tau_j)
  
  checkmate::assertNumeric(w_j, lower = 0, upper = 1, len = 1, .var.name = error_w_j)
  
  checkmate::assertNumeric(
    target_means,
    any.missing = FALSE,
    .var.name   = error_target_means
  )
  
  checkmate::assertTRUE(
    length(mu_j) == length(tau_j),
    .var.name = "'mu_j' and 'tau_j' must have the same length"
  )
  
  checkmate::assertTRUE(
    length(mu_j) == length(target_means),
    .var.name = "'mu_j' and 'target_means' must have the same length"
  )
  
  checkmate::assertNumber(sigma_shape, .var.name = error_sigma_shape)
  checkmate::assertTRUE(sigma_shape > 0, .var.name = error_sigma_shape)
  
  checkmate::assertNumber(sigma_rate, .var.name = error_sigma_rate)
  checkmate::assertTRUE(sigma_rate > 0, .var.name = error_sigma_rate)
  
  prior_parameters <- list(
    mu_mean      = mu_mean,
    mu_sd        = mu_sd,
    tau_scale    = tau_scale,
    mu_j         = mu_j,
    tau_j        = tau_j,
    w_j          = w_j,
    target_means = target_means,
    sigma_shape  = sigma_shape,
    sigma_rate   = sigma_rate
  )
  
  prior_parameters_list <- list(normal = prior_parameters)
  class(prior_parameters_list) <- "prior_parameters_list"
  
  return(prior_parameters_list)
}

