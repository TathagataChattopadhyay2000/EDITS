set.seed(123)

sc_hist_norm <- simulateScenarios(
  n_subjects_list = list(c(50, 25, 30)),
  means_list      = list(c(4.8, 5.8, 6.5)),
  sds_list        = list(c(0.0, 1.5, 1.1)),
  n_trials        = 20,
  endpoint        = "normal"
)

print(sc_hist_norm)

an_hist_norm <- performAnalyses(
  scenario_list         = sc_hist_norm,
  method_names          = "normal",
  prior_parameters_list = getPriorParameters(
    endpoint     = "normal",
    target_means = c(5.0, 5.0, 5.0)
  ),
  n_mcmc_iterations     = 200,
  nbins                 = 5,
  verbose               = TRUE
)

go_hist_norm <- getGoDecisions(
  analyses_list   = an_hist_norm,
  cohort_names    = c("theta_2", "theta_3"),
  evidence_levels = c(0.80, 0.80),
  boundary_rules  = quote(c(TRUE, x[2] > 5.5, x[3] > 5.5))
)

sc_hist_norm_2 <- continueRecruitment(
  n_subjects_add_list = list(c(10, 10)),
  decisions_list      = go_hist_norm,
  method_name         = "normal"
)

print(sc_hist_norm_2)
