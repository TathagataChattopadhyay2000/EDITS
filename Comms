setPriorParametersBerryMix <- function(mu_mean, mu_sd, w_mu, tau_scale) {

  # validations
  checkmate::assertNumber(tau_scale)
  checkmate::assertTRUE(tau_scale > 0)

  checkmate::assertNumeric(mu_mean, any.missing = FALSE)
  checkmate::assertNumeric(mu_sd, any.missing = FALSE)
  checkmate::assertNumeric(w_mu, any.missing = FALSE, lower = 0, upper = 1)

  checkmate::assertTRUE(length(mu_mean) == length(mu_sd))
  checkmate::assertTRUE(length(mu_mean) == length(w_mu))
  checkmate::assertTRUE(all(mu_sd > 0))
  checkmate::assertTRUE(isTRUE(all.equal(sum(w_mu), 1)))

  prior_parameters <- list(
    mu_mean   = as.numeric(mu_mean),
    mu_sd     = as.numeric(mu_sd),
    w_mu      = as.numeric(w_mu),
    tau_scale = tau_scale
  )

  out <- list(berry_mix = prior_parameters)
  class(out) <- "prior_parameters_list"
  out
}
