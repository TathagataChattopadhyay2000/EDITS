setPriorParametersPooledMix <- function(w, a, b) {

  checkmate::assertNumeric(w, any.missing=FALSE, lower=0, upper=1)
  checkmate::assertTRUE(isTRUE(all.equal(sum(w), 1)))

  checkmate::assertNumeric(a, any.missing=FALSE)
  checkmate::assertNumeric(b, any.missing=FALSE)
  checkmate::assertTRUE(all(a > 0))
  checkmate::assertTRUE(all(b > 0))
  checkmate::assertTRUE(length(w) == length(a) && length(a) == length(b))

  out <- list(pooled_mix = list(w = w, a = a, b = b))
  class(out) <- "prior_parameters_list"
  out
}

