getAllCohortNames <- function(analyses_list) {
  
  endpoint <- if (!is.null(analyses_list[[1]]$scenario_data$endpoint)) {
    analyses_list[[1]]$scenario_data$endpoint
  } else {
    "binary"
  }
  
  prefix <- if (endpoint == "binary") "p_" else "theta_"
  
  Reduce(
    intersect,
    sapply(analyses_list, function (x) {
      lapply(x$quantiles_list, function (y) {
        post_names <- Reduce(intersect, lapply(y, colnames))
        post_names[grep(paste0("^", prefix), post_names)]
      })
    })
  )
}
