## Operating Characteristics (OC) for your NORMAL endpoint model (unknown common sigma)
## Produces: bias/var/MSE/RMSE, per-cohort type I error & power, FWER, FDR
## Includes: calibration of evidence level (gamma) to control FWER at alpha_FWER
##
## Assumptions about your package API (as implemented in our work):
## - simulateScenarios(..., endpoint="normal", means_list=..., sds_list=..., n_trials=R)
## - performAnalyses(..., method_names="normal", nbins or bin_breaks, evidence_levels=...)
## - getEstimates(analyses_list, alpha_level=...) returns theta_1..theta_J rows with Mean, SD, 2.5%, 97.5%
## - getGoDecisions(analyses_list, cohort_names=c("theta_1"..), evidence_levels=rep(gamma,J), boundary_rules=quote(c(...)))
##   where x[j] is the selected posterior quantile for theta_j (based on evidence level)
##
## Interpretation of decision rule here:
## - We use: Go if lower credible bound at level (1-gamma) is > delta
##   i.e. gamma=0.975 means lower 2.5% bound > delta (conservative).
##
## NOTE: This matches the spirit of posterior probability thresholding:
## - Go if P(theta > delta) > gamma  is equivalent to lower (1-gamma) quantile > delta.

## ----------------------------
## Utilities
## ----------------------------

.get_theta_est <- function(an, alpha = 0.05) {
  est <- getEstimates(
    analyses_list   = an,
    add_parameters  = NULL,
    point_estimator = "mean",
    alpha_level     = alpha
  )
  est$normal$scenario_1
}

.get_go_matrix <- function(an, delta, gamma, overall_min_gos = 1) {
  J <- ncol(an$scenario_1$scenario_data$n_subjects)
  cohort_names <- paste0("theta_", seq_len(J))
  evidence_levels <- rep(gamma, J)

  boundary_rates <- rep(delta, J)  # used inside decision_rule environment

  dec <- getGoDecisions(
    analyses_list   = an,
    cohort_names    = cohort_names,
    evidence_levels = evidence_levels,
    boundary_rules  = quote(c(
      x[1] > boundary_rates[1],
      x[2] > boundary_rates[2],
      x[3] > boundary_rates[3]
    )),
    overall_min_gos = overall_min_gos
  )

  ## return logical matrix with columns overall + decision_1..decision_J
  dec$scenario_1$decisions_list$normal
}

## If J != 3, build boundary_rules programmatically
.make_boundary_rules <- function(J) {
  ## returns quote(c(x[1] > boundary_rates[1], ..., x[J] > boundary_rates[J]))
  exprs <- lapply(seq_len(J), function(j) bquote(x[.(j)] > boundary_rates[.(j)]))
  as.call(c(quote(c), exprs))
}

.get_go_matrix_generalJ <- function(an, delta, gamma, overall_min_gos = 1) {
  J <- ncol(an$scenario_1$scenario_data$n_subjects)
  cohort_names <- paste0("theta_", seq_len(J))
  evidence_levels <- rep(gamma, J)

  boundary_rates <- rep(delta, J)
  br <- .make_boundary_rules(J)

  dec <- getGoDecisions(
    analyses_list   = an,
    cohort_names    = cohort_names,
    evidence_levels = evidence_levels,
    boundary_rules  = br,
    overall_min_gos = overall_min_gos
  )

  dec$scenario_1$decisions_list$normal
}

## ----------------------------
## Core OC runner for one truth scenario
## ----------------------------

run_oc_one_scenario <- function(
  theta_true,         # numeric length J
  sigma_true,         # scalar
  n_vec,              # integer length J
  R = 200,            # number of trial realizations
  mcmc_iter = 500,    # per unique trial
  nbins = 20,         # binning control (or use bin_breaks instead)
  delta = 0.0,        # decision threshold on theta
  gamma = 0.975,      # evidence level (see above)
  alpha_ci = 0.05,    # for bias/coverage reporting
  verbose = FALSE
) {
  stopifnot(length(theta_true) == length(n_vec))
  J <- length(theta_true)

  ## simulate R trial realizations
  scen <- simulateScenarios(
    n_subjects_list = list(as.integer(n_vec)),
    means_list      = list(as.numeric(theta_true)),
    sds_list        = list(rep(sigma_true, J)),
    endpoint        = "normal",
    n_trials        = R
  )

  ## fit once (handles all unique trials internally)
  an <- performAnalyses(
    scenario_list     = scen,
    method_names      = "normal",
    n_mcmc_iterations = mcmc_iter,
    nbins             = nbins,
    ## ensure performAnalyses stores needed gamma levels
    evidence_levels   = sort(unique(c(0.025, 0.05, 0.5, 0.8, 0.9, 0.95, 0.975, gamma))),
    verbose           = verbose
  )

  ## Extract posterior summaries per realization:
  ## We use getEstimates(an) which returns averaged metrics across trials.
  ## For OC we need per-trial decisions; for bias/coverage we can compute using per-trial quantiles_list.
  ##
  ## Minimal approach: compute bias/coverage from per-trial quantiles_list directly.
  qlist <- an$scenario_1$quantiles_list$normal  # list length R of posterior quantile matrices

  ## Identify row names for CI bounds used in qlist matrices
  ## They are like "2.5%" "97.5%" plus "Mean"/"SD"
  lo_name <- paste0(alpha_ci/2 * 100, "%")
  hi_name <- paste0((1 - alpha_ci/2) * 100, "%")

  theta_cols <- paste0("theta_", seq_len(J))

  post_mean <- matrix(NA_real_, R, J)
  post_lo   <- matrix(NA_real_, R, J)
  post_hi   <- matrix(NA_real_, R, J)

  for (r in seq_len(R)) {
    M <- qlist[[r]]
    post_mean[r, ] <- as.numeric(M["Mean", theta_cols])
    post_lo[r, ]   <- as.numeric(M[lo_name, theta_cols])
    post_hi[r, ]   <- as.numeric(M[hi_name, theta_cols])
  }

  ## estimation OC
  theta_mat <- matrix(theta_true, nrow = R, ncol = J, byrow = TRUE)
  bias <- colMeans(post_mean - theta_mat)
  var  <- apply(post_mean, 2, var)
  mse  <- colMeans((post_mean - theta_mat)^2)
  rmse <- sqrt(mse)
  cover <- colMeans((post_lo <= theta_mat) & (post_hi >= theta_mat))

  ## decision OC (per-trial go/no-go)
  ## Use getGoDecisions so it stays aligned with your package logic
  go_mat <- .get_go_matrix_generalJ(an, delta = delta, gamma = gamma, overall_min_gos = 1)

  ## per-cohort go rates (power or type I depending on truth)
  go_rates <- colMeans(go_mat[, paste0("decision_", seq_len(J)), drop = FALSE])
  overall_go_rate <- mean(go_mat[, "overall"])

  list(
    analyses = an,
    theta_true = theta_true,
    sigma_true = sigma_true,
    n_vec = n_vec,
    delta = delta,
    gamma = gamma,
    R = R,
    estimation = list(
      bias = bias,
      var = var,
      mse = mse,
      rmse = rmse,
      coverage = cover
    ),
    decisions = list(
      per_cohort_go_rate = go_rates,
      overall_go_rate = overall_go_rate
    )
  )
}

## ----------------------------
## FWER + FDR across multiple truth scenarios
## ----------------------------

## FWER under global null: all theta_true <= delta (we use overall go rate with overall_min_gos=1)
run_fwer_null <- function(
  J, sigma_true, n_vec, delta,
  R = 500, mcmc_iter = 500, nbins = 20,
  gamma = 0.975
) {
  theta_null <- rep(delta, J)
  oc <- run_oc_one_scenario(
    theta_true = theta_null,
    sigma_true = sigma_true,
    n_vec      = n_vec,
    R          = R,
    mcmc_iter  = mcmc_iter,
    nbins      = nbins,
    delta      = delta,
    gamma      = gamma,
    verbose    = FALSE
  )
  oc$decisions$overall_go_rate
}

## FDR under mixed null/alt:
## true_null is logical length J (TRUE = null cohort)
run_fdr_mixed <- function(
  theta_true, true_null, sigma_true, n_vec, delta,
  R = 500, mcmc_iter = 500, nbins = 20,
  gamma = 0.975
) {
  oc <- run_oc_one_scenario(
    theta_true = theta_true,
    sigma_true = sigma_true,
    n_vec      = n_vec,
    R          = R,
    mcmc_iter  = mcmc_iter,
    nbins      = nbins,
    delta      = delta,
    gamma      = gamma,
    verbose    = FALSE
  )

  go_mat <- .get_go_matrix_generalJ(oc$analyses, delta = delta, gamma = gamma, overall_min_gos = 1)
  go_only <- go_mat[, paste0("decision_", seq_len(length(theta_true))), drop = FALSE]

  ## FDP per replicate: false discoveries / discoveries
  FDP <- apply(go_only, 1, function(z) {
    disc <- which(z)
    if (length(disc) == 0) return(0)
    false_disc <- sum(true_null[disc])
    false_disc / length(disc)
  })

  list(
    FDR = mean(FDP),
    per_cohort_go_rate = colMeans(go_only)
  )
}

## ----------------------------
## Calibrate gamma to control FWER at alpha_FWER
## ----------------------------

calibrate_gamma <- function(
  gamma_grid,           # e.g. c(0.8, 0.9, 0.95, 0.975, 0.99)
  J, sigma_true, n_vec, delta,
  alpha_FWER = 0.05,
  R = 500, mcmc_iter = 500, nbins = 20
) {
  fwer_vals <- sapply(gamma_grid, function(gam) {
    run_fwer_null(
      J = J, sigma_true = sigma_true, n_vec = n_vec, delta = delta,
      R = R, mcmc_iter = mcmc_iter, nbins = nbins, gamma = gam
    )
  })

  ## choose smallest gamma that achieves FWER <= alpha_FWER (most powerful under constraint)
  ok <- which(fwer_vals <= alpha_FWER)
  if (length(ok) == 0) {
    best <- which.min(fwer_vals)  # no one meets target; return closest
  } else {
    best <- ok[1]
  }

  list(
    gamma_grid = gamma_grid,
    fwer = fwer_vals,
    gamma_star = gamma_grid[best]
  )
}

## ----------------------------
## Example: run the full OC suite
## ----------------------------

## Settings
J <- 3
n_vec <- c(10, 20, 30)
sigma_true <- 2.0
delta <- 2.5

## 1) Calibrate gamma on global null
gamma_grid <- c(0.8, 0.9, 0.95, 0.975, 0.99)

cal <- calibrate_gamma(
  gamma_grid = gamma_grid,
  J = J, sigma_true = sigma_true, n_vec = n_vec, delta = delta,
  alpha_FWER = 0.05,
  R = 300, mcmc_iter = 500, nbins = 20
)
print(cal)

gamma_star <- cal$gamma_star

## 2) Power scenario (one effective cohort)
theta_alt <- c(2.0, 2.0, 3.2)  # only cohort 3 above delta
oc_alt <- run_oc_one_scenario(
  theta_true = theta_alt,
  sigma_true = sigma_true,
  n_vec      = n_vec,
  R          = 300,
  mcmc_iter  = 500,
  nbins      = 20,
  delta      = delta,
  gamma      = gamma_star,
  verbose    = FALSE
)
print(oc_alt$estimation)
print(oc_alt$decisions)

## 3) FDR in a mixed scenario
true_null <- c(TRUE, TRUE, FALSE)
fdr_res <- run_fdr_mixed(
  theta_true = theta_alt,
  true_null  = true_null,
  sigma_true = sigma_true,
  n_vec      = n_vec,
  delta      = delta,
  R          = 300,
  mcmc_iter  = 500,
  nbins      = 20,
  gamma      = gamma_star
)
print(fdr_res)
