install.packages("RBesT")
library(RBesT)
library(bhmbasket)

## -----------------------------
## toy data
## -----------------------------
n <- c(20, 18, 22)
r <- c(6, 5, 9)
probs <- c(0.025, 0.5, 0.975)

trial_data <- createTrial(
  n_subjects   = n,
  n_responders = r
)

## =============================
## 1) stratified_mix vs RBesT
## =============================

## same 2-component beta-mixture prior for each cohort
## rows = mixture components, cols = cohorts
w <- c(0.8, 0.2)

a_j <- rbind(
  c(4, 5, 6),
  c(1, 1, 1)
)

b_j <- rbind(
  c(12, 10, 9),
  c(1, 1, 1)
)

## bhmbasket
pp_strat_mix <- setPriorParametersStratifiedMix(
  w   = w,
  a_j = a_j,
  b_j = b_j
)

res_bhm <- performAnalyses(
  scenario_list         = trial_data,
  method_names          = "stratified_mix",
  prior_parameters_list = pp_strat_mix,
  n_mcmc_iterations     = 2000,
  verbose               = FALSE
)

bhm_tab <- res_bhm[[1]]$quantiles_list$stratified_mix
bhm_tab

## RBesT: same prior, cohort by cohort
rbest_tab <- sapply(seq_along(n), function(j) {
  prior_j <- do.call(
    RBesT::mixbeta,
    lapply(seq_along(w), function(k) c(w[k], a_j[k, j], b_j[k, j]))
  )

  post_j <- RBesT::postmix(prior_j, n = n[j], r = r[j])

  summ_j <- summary(post_j, probs = probs)

  c(
    q025 = unname(summ_j["2.5%"]),
    q500 = unname(summ_j["50%"]),
    q975 = unname(summ_j["97.5%"]),
    Mean = unname(summ_j["mean"]),
    SD   = unname(summ_j["sd"])
  )
})

colnames(rbest_tab) <- paste0("cohort_", seq_along(n))
rbest_tab

## bhmbasket table in the same shape
bhm_cmp <- bhm_tab[c("2.5%", "50%", "97.5%", "Mean", "SD"), paste0("p_", 1:3)]
colnames(bhm_cmp) <- paste0("cohort_", 1:3)
rownames(bhm_cmp) <- c("q025", "q500", "q975", "Mean", "SD")

## side-by-side comparison
comparison <- lapply(seq_along(n), function(j) {
  out <- cbind(
    bhmbasket = bhm_cmp[, j],
    RBesT     = rbest_tab[, j]
  )
  rownames(out) <- c("q025", "q500", "q975", "Mean", "SD")
  out
})

names(comparison) <- paste0("cohort_", seq_along(n))
comparison

## differences: bhmbasket - RBesT
diff_tab <- sapply(seq_along(n), function(j) bhm_cmp[, j] - rbest_tab[, j])
colnames(diff_tab) <- paste0("cohort_", seq_along(n))
rownames(diff_tab) <- c("q025", "q500", "q975", "Mean", "SD")
diff_tab


## ===========================================
## 2) exnex_mix with EX turned off vs RBesT
## ===========================================
## With w_j = 0, the EX part gets zero weight, so only the NEX mixture remains.
## That makes the comparison to a pure beta-mixture posterior in RBesT natural.  [oai_citation:1‡Rdrr.io](https://rdrr.io/cran/RBesT/man/postmix.html?utm_source=chatgpt.com)

w_nex <- c(0.8, 0.2)

mean_nex <- rbind(
  qlogis(c(4 / (4 + 12), 5 / (5 + 10), 6 / (6 + 9))),
  qlogis(c(0.5, 0.5, 0.5))
)

sd_nex <- rbind(
  c(0.5, 0.5, 0.5),
  c(2.0, 2.0, 2.0)
)

pp_exnex_mix_zero_ex <- setPriorParametersExNex(
  mu_mean   = 0,
  mu_sd     = 1,
  tau_scale = 0.5,
  w_j       = 0,
  w_nex     = w_nex,
  mean_nex  = mean_nex,
  sd_nex    = sd_nex
)

names(pp_exnex_mix_zero_ex) <- "exnex_mix"

res_ex0 <- performAnalyses(
  scenario_list         = trial_data,
  method_names          = "exnex_mix",
  prior_parameters_list = pp_exnex_mix_zero_ex,
  n_mcmc_iterations     = 4000,
  verbose               = FALSE
)

ex0_tab <- res_ex0[[1]]$quantiles_list$exnex_mix
ex0_tab

## RBesT comparison
## Convert each logit-normal NEX mixture component to an approximate beta prior
## using its mean and variance on the probability scale.
logitnorm_to_beta <- function(mu, sd) {
  draws <- plogis(rnorm(200000, mean = mu, sd = sd))
  m <- mean(draws)
  v <- var(draws)
  phi <- m * (1 - m) / v - 1
  c(a = m * phi, b = (1 - m) * phi)
}

rbest_ex0_tab <- sapply(seq_along(n), function(j) {
  ab <- t(sapply(seq_along(w_nex), function(k) {
    logitnorm_to_beta(mean_nex[k, j], sd_nex[k, j])
  }))

  prior_j <- do.call(
    RBesT::mixbeta,
    lapply(seq_along(w_nex), function(k) c(w_nex[k], ab[k, "a"], ab[k, "b"]))
  )

  post_j <- RBesT::postmix(prior_j, n = n[j], r = r[j])
  summ_j <- summary(post_j, probs = probs)

  c(
    q025 = unname(summ_j["2.5%"]),
    q500 = unname(summ_j["50%"]),
    q975 = unname(summ_j["97.5%"]),
    Mean = unname(summ_j["mean"]),
    SD   = unname(summ_j["sd"])
  )
})

colnames(rbest_ex0_tab) <- paste0("cohort_", seq_along(n))
rbest_ex0_tab

ex0_cmp <- ex0_tab[c("2.5%", "50%", "97.5%", "Mean", "SD"), paste0("p_", 1:3)]
colnames(ex0_cmp) <- paste0("cohort_", 1:3)
rownames(ex0_cmp) <- c("q025", "q500", "q975", "Mean", "SD")

ex0_diff <- sapply(seq_along(n), function(j) ex0_cmp[, j] - rbest_ex0_tab[, j])
colnames(ex0_diff) <- paste0("cohort_", seq_along(n))
rownames(ex0_diff) <- c("q025", "q500", "q975", "Mean", "SD")
ex0_diff
