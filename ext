} else if (method_name == "berry_map") {

  # prior_parameters must contain: w_psi, a_psi, b_psi, mean_mu, mu_sd or precision_mu, tau_scale
  # Here we keep the same mu/tau parameterization style you already use.

  # K_psi inferred from number of rows
  K_psi <- nrow(prior_parameters$a_psi)

  j_data <- list(
    # baseline mixture inputs
    K_psi = K_psi,
    w_psi = prior_parameters$w_psi,  # matrix K_psi x J
    a_psi = prior_parameters$a_psi,  # matrix K_psi x J
    b_psi = prior_parameters$b_psi,  # matrix K_psi x J

    # Berry shift hyperpriors
    mean_mu      = prior_parameters$mu_mean,
    precision_mu = prior_parameters$mu_sd^-2,
    precision_tau = prior_parameters$tau_scale^-2,

    # will be filled per trial in getPostQuantilesOfTrial()
    J = length(target_rates)  # equals number of cohorts
  )

  j_model_file <- getModelFile("berry_map")

  # save p for your existing quantile workflow; add others if you want
  j_parameters <- c("p", "psi", "theta", "mu", "tau")
}
