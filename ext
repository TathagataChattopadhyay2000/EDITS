setPriorParametersBerryMix <- function(mu_mean = NULL, mu_sd = NULL, w_mu = NULL, tau_scale,
                                       mixbeta = NULL, n_mc = 200000, K_mu = NULL) {

  # --- If user provides an RBesT beta-mixture prior, convert it ---
  if (!is.null(mixbeta)) {

    # draw from mixbeta on probability scale
    p <- RBesT::rmix(mixbeta, n = n_mc)

    # transform to logit scale (mu lives on log-odds scale)
    x <- stats::qlogis(p)

    # fit normal mixture to x (user decides/you implement this fitter)
    # Must return list(w, mean, sd) of length K_mu (or chosen automatically)
    fit <- fit_mixnorm(x, K = K_mu)   # <-- implement or plug in your fitter

    mu_mean <- fit$mean
    mu_sd   <- fit$sd
    w_mu    <- fit$w
  }

  # --- Validate numeric inputs ---
  checkmate::assertNumber(tau_scale, lower = 0)
  checkmate::assertTRUE(tau_scale > 0)

  checkmate::assertNumeric(mu_mean, any.missing = FALSE)
  checkmate::assertNumeric(mu_sd, any.missing = FALSE)
  checkmate::assertNumeric(w_mu, any.missing = FALSE, lower = 0, upper = 1)

  checkmate::assertTRUE(length(mu_mean) == length(mu_sd))
  checkmate::assertTRUE(length(mu_mean) == length(w_mu))
  checkmate::assertTRUE(all(mu_sd > 0))
  checkmate::assertTRUE(isTRUE(all.equal(sum(w_mu), 1)))

  prior_parameters <- list(
    mu_mean   = as.numeric(mu_mean),
    mu_sd     = as.numeric(mu_sd),
    w_mu      = as.numeric(w_mu),
    tau_scale = tau_scale
  )

  out <- list(berry_mix = prior_parameters)
  class(out) <- "prior_parameters_list"
  out
}
