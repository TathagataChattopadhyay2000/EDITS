getPriorParametersExNexMix <- function(

  target_rates,
  tau_scale = 1,
  n_worth   = 1,
  w_j       = 0.5,
  w_nex     = c(0.8, 0.2)

) {

  error_target_rates <- "Providing a vector of numerics in (0, 1) for the argument 'target_rates'"
  error_tau_scale    <- "Providing a positive numeric for the argument 'tau_scale'"
  error_n_worth      <- "Providing a positive integer for the argument 'n_worth'"
  error_w_j          <- "Providing a numeric in (0, 1) for the argument 'w_j'"
  error_w_nex        <- "Providing a numeric vector of weights in [0,1] summing to 1 for the argument 'w_nex'"

  checkmate::assertNumeric(target_rates, any.missing = FALSE, .var.name = error_target_rates)
  checkmate::assertTRUE(all(target_rates > 0 & target_rates < 1), .var.name = error_target_rates)

  checkmate::assertNumber(tau_scale, .var.name = error_tau_scale)
  checkmate::assertTRUE(tau_scale > 0, .var.name = error_tau_scale)

  checkmate::assertInt(n_worth, lower = 1, .var.name = error_n_worth)

  checkmate::assertNumeric(w_j, lower = 0, upper = 1, len = 1, .var.name = error_w_j)

  checkmate::assertNumeric(w_nex, any.missing = FALSE, lower = 0, upper = 1, .var.name = error_w_nex)
  checkmate::assertTRUE(isTRUE(all.equal(sum(w_nex), 1)), .var.name = error_w_nex)

  target_rate_max_var <- target_rates[abs(target_rates - 0.5) == max(abs(target_rates - 0.5))][1]

  mu_var <- getMuVar(target_rate_max_var, tau_scale, n_worth)

  if (mu_var <= 0) {
    stop(simpleError(paste(
      "The provided input parameters lead to a variance of mu <= 0.",
      "Consider to decrease 'tau_scale' or 'n_worth'"
    )))
  }

  K_nex <- length(w_nex)
  J     <- length(target_rates)

  nex_mean <- matrix(NA_real_, nrow = K_nex, ncol = J)
  nex_sd   <- matrix(NA_real_, nrow = K_nex, ncol = J)

  ## component 1: informative cohort-specific NEX prior
  nex_mean[1, ] <- logit(target_rates)
  nex_sd[1, ]   <- sqrt(getMuVar(target_rates, 0, n_worth))

  ## component 2: vague cohort-specific NEX prior
  if (K_nex >= 2) {
    for (k in 2:K_nex) {
      nex_mean[k, ] <- logit(target_rates)
      nex_sd[k, ]   <- sqrt(getMuVar(target_rates, 0, n_worth)) * 5
    }
  }

  prior_parameters <- list(
    mu_mean   = logit(target_rate_max_var),
    mu_sd     = sqrt(mu_var),
    tau_scale = tau_scale,
    w_j       = w_j,
    w_nex     = w_nex,
    nex_mean  = nex_mean,
    nex_sd    = nex_sd
  )

  out <- list(exnex_mix = prior_parameters)
  class(out) <- "prior_parameters_list"
  out
}

setPriorParametersExNexMix <- function(

  mu_mean,
  mu_sd,
  tau_scale,
  w_j,
  w_nex,
  nex_mean,
  nex_sd

) {

  error_mu_mean   <- "Providing numeric(s) for the argument 'mu_mean'"
  error_mu_sd     <- "Providing positive numeric(s) for the argument 'mu_sd'"
  error_tau_scale <- "Providing a positive numeric for the argument 'tau_scale'"
  error_w_j       <- "Providing numeric(s) in [0,1] for the argument 'w_j'"
  error_w_nex     <- "Providing numeric vector of weights in [0,1] summing to 1 for the argument 'w_nex'"
  error_nex_mean  <- "Providing a numeric matrix for the argument 'nex_mean'"
  error_nex_sd    <- "Providing a positive numeric matrix for the argument 'nex_sd'"
  error_dim       <- "'nex_mean' and 'nex_sd' must have the same dimensions; nrow(nex_mean) must equal length(w_nex)"

  checkmate::assertNumeric(mu_mean, any.missing = FALSE, .var.name = error_mu_mean)
  checkmate::assertNumeric(mu_sd, any.missing = FALSE, lower = 0, .var.name = error_mu_sd)
  checkmate::assertTRUE(all(mu_sd > 0), .var.name = error_mu_sd)
  checkmate::assertTRUE(length(mu_mean) == length(mu_sd), .var.name = "'mu_mean' and 'mu_sd' must have same length")

  checkmate::assertNumber(tau_scale, .var.name = error_tau_scale)
  checkmate::assertTRUE(tau_scale > 0, .var.name = error_tau_scale)

  checkmate::assertNumeric(w_j, any.missing = FALSE, lower = 0, upper = 1, .var.name = error_w_j)
  if (length(mu_mean) > 1) {
    checkmate::assertTRUE(length(w_j) == length(mu_mean) + 1,
                          .var.name = "'w_j' must have length equal to length(mu_mean) + 1 if length(mu_mean) > 1")
    checkmate::assertTRUE(isTRUE(all.equal(sum(w_j), 1)),
                          .var.name = "Sum over items in 'w_j' must equal 1 if length(w_j) > 1")
  } else {
    checkmate::assertTRUE(length(w_j) %in% c(1, 2),
                          .var.name = "'w_j' must have length 1 or 2 if length(mu_mean) = 1")
    if (length(w_j) == 2) {
      checkmate::assertTRUE(isTRUE(all.equal(sum(w_j), 1)),
                            .var.name = "Sum over items in 'w_j' must equal 1 if length(w_j) > 1")
    }
  }

  checkmate::assertNumeric(w_nex, any.missing = FALSE, lower = 0, upper = 1, .var.name = error_w_nex)
  checkmate::assertTRUE(isTRUE(all.equal(sum(w_nex), 1)), .var.name = error_w_nex)

  checkmate::assertTRUE(is.matrix(nex_mean), .var.name = error_nex_mean)
  checkmate::assertTRUE(is.matrix(nex_sd), .var.name = error_nex_sd)
  checkmate::assertTRUE(all(nex_sd > 0), .var.name = error_nex_sd)
  checkmate::assertTRUE(all(dim(nex_mean) == dim(nex_sd)), .var.name = error_dim)
  checkmate::assertTRUE(nrow(nex_mean) == length(w_nex), .var.name = error_dim)

  prior_parameters <- list(
    mu_mean   = as.numeric(mu_mean),
    mu_sd     = as.numeric(mu_sd),
    tau_scale = tau_scale,
    w_j       = as.numeric(w_j),
    w_nex     = as.numeric(w_nex),
    nex_mean  = nex_mean,
    nex_sd    = nex_sd
  )

  out <- list(exnex_mix = prior_parameters)
  class(out) <- "prior_parameters_list"
  out
}

getPriorParametersExNexAdjMix <- function(

  target_rates,
  tau_scale = 1,
  n_worth   = 1,
  w_j       = 0.5,
  w_nex     = c(0.8, 0.2)

) {

  prior_parameters <- getPriorParametersExNexMix(
    target_rates = target_rates,
    tau_scale    = tau_scale,
    n_worth      = n_worth,
    w_j          = w_j,
    w_nex        = w_nex
  )[[1]]

  prior_parameters$mu_mean      <- 0
  prior_parameters$nex_mean[1,] <- 0
  if (nrow(prior_parameters$nex_mean) >= 2) {
    for (k in 2:nrow(prior_parameters$nex_mean)) {
      prior_parameters$nex_mean[k, ] <- 0
    }
  }

  out <- list(exnex_adj_mix = prior_parameters)
  class(out) <- "prior_parameters_list"
  out
}

setPriorParametersExNexAdjMix <- function(

  mu_mean,
  mu_sd,
  tau_scale,
  w_j,
  w_nex,
  nex_mean,
  nex_sd

) {
  out <- setPriorParametersExNexMix(
    mu_mean   = mu_mean,
    mu_sd     = mu_sd,
    tau_scale = tau_scale,
    w_j       = w_j,
    w_nex     = w_nex,
    nex_mean  = nex_mean,
    nex_sd    = nex_sd
  )
  names(out) <- "exnex_adj_mix"
  out
}
