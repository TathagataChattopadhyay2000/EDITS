setPriorParametersBerryMix <- function(
  mu_mean = NULL, mu_sd = NULL, w_mu = NULL, tau_scale,
  # optional: provide mixbeta on probability scale instead of mu params
  mixbeta = NULL,               # either 3xK matrix (rows w,a,b) OR list(w=,a=,b=)
  n_mc = 200000,                # MC sample size for conversion
  K_mu = 2                      # number of normal-mixture components to fit
) {

  # --- If mixbeta is provided, convert it to mixnorm parameters for mu ---
  if (!is.null(mixbeta)) {

    # extract w,a,b from either matrix or list
    if (is.matrix(mixbeta)) {
      w <- as.numeric(mixbeta["w", ])
      a <- as.numeric(mixbeta["a", ])
      b <- as.numeric(mixbeta["b", ])
    } else if (is.list(mixbeta)) {
      w <- as.numeric(mixbeta$w)
      a <- as.numeric(mixbeta$a)
      b <- as.numeric(mixbeta$b)
    } else {
      stop("'mixbeta' must be a 3xK matrix with rows w/a/b or a list(w=,a=,b=).")
    }

    # basic validation
    if (length(w) == 0L || length(w) != length(a) || length(a) != length(b)) {
      stop("mixbeta components must have equal non-zero length: w, a, b.")
    }
    if (any(w < 0) || abs(sum(w) - 1) > 1e-8) stop("mixbeta weights must be >=0 and sum to 1.")
    if (any(a <= 0) || any(b <= 0)) stop("mixbeta Beta parameters a,b must be > 0.")

    # sample from beta mixture using base R
    k <- sample.int(length(w), size = n_mc, replace = TRUE, prob = w)
    p <- stats::rbeta(n_mc, shape1 = a[k], shape2 = b[k])

    # guard against numerical infinities (shouldn't happen for Beta draws, but safe)
    eps <- 1e-12
    p <- pmin(pmax(p, eps), 1 - eps)

    # logit transform
    x <- stats::qlogis(p)

    # fit mixture of normals to x (you must implement this function once)
    fit <- fitMixnormEM(x, K = K_mu)  # returns list(w, mean, sd)

    mu_mean <- fit$mean
    mu_sd   <- fit$sd
    w_mu    <- fit$w
  }

  # --- Validate direct mu inputs (or those obtained from conversion) ---
  checkmate::assertNumber(tau_scale)
  checkmate::assertTRUE(tau_scale > 0)

  checkmate::assertNumeric(mu_mean, any.missing = FALSE)
  checkmate::assertNumeric(mu_sd, any.missing = FALSE)
  checkmate::assertNumeric(w_mu, any.missing = FALSE, lower = 0, upper = 1)

  checkmate::assertTRUE(length(mu_mean) == length(mu_sd))
  checkmate::assertTRUE(length(mu_mean) == length(w_mu))
  checkmate::assertTRUE(all(mu_sd > 0))
  checkmate::assertTRUE(isTRUE(all.equal(sum(w_mu), 1)))

  prior_parameters <- list(
    mu_mean   = as.numeric(mu_mean),
    mu_sd     = as.numeric(mu_sd),
    w_mu      = as.numeric(w_mu),
    tau_scale = tau_scale
  )

  out <- list(berry_mix = prior_parameters)
  class(out) <- "prior_parameters_list"
  out
}
