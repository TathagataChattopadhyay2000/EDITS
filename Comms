getPostQuantilesPooledMix <- function(j_data, quantiles, n_mc = 200000) {

  # pooled totals from current trial data
  r_tot <- sum(j_data$r)
  n_tot <- sum(j_data$n)

  w <- j_data$w
  a <- j_data$a
  b <- j_data$b

  # component-wise posterior parameters
  a_post <- a + r_tot
  b_post <- b + (n_tot - r_tot)

  # update mixture weights using beta-binomial evidence
  log_fk <- lbeta(a_post, b_post) - lbeta(a, b)  # proportional to marginal likelihood
  log_w  <- log(w) + log_fk
  w_post <- exp(log_w - max(log_w))
  w_post <- w_post / sum(w_post)

  # MC draws from mixture posterior for quantiles
  k <- sample.int(length(w_post), size = n_mc, replace = TRUE, prob = w_post)
  p_draw <- stats::rbeta(n_mc, a_post[k], b_post[k])

  q <- stats::quantile(p_draw, probs = quantiles)

  # keep same output shape as pooled(): matrix with p_1..p_J columns
  posterior_quantiles <- matrix(q, nrow = length(quantiles), ncol = length(j_data$r))
  colnames(posterior_quantiles) <- paste0("p_", seq_along(j_data$r))
  rownames(posterior_quantiles) <- paste0(quantiles * 100, "%")

  # mixture mean/sd (closed form)
  m_k <- a_post / (a_post + b_post)
  v_k <- (a_post * b_post) / ((a_post + b_post)^2 * (a_post + b_post + 1))
  m   <- sum(w_post * m_k)
  v   <- sum(w_post * (v_k + (m_k - m)^2))

  posterior_quantiles <- rbind(posterior_quantiles, Mean = m, SD = sqrt(v))

  posterior_quantiles
}

