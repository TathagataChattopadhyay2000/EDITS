rbest_one <- function(n, r, w, a, b, probs = c(0.025, 0.5, 0.975), nsim = 100000) {
  prior <- do.call(
    RBesT::mixbeta,
    lapply(seq_along(w), function(k) c(w[k], a[k], b[k]))
  )

  post <- RBesT::postmix(prior, n = n, r = r)

  draws <- RBesT::rmix(nsim, post)

  c(
    q025 = stats::quantile(draws, probs[1]),
    q500 = stats::quantile(draws, probs[2]),
    q975 = stats::quantile(draws, probs[3]),
    Mean = mean(draws),
    SD   = stats::sd(draws)
  )
}
